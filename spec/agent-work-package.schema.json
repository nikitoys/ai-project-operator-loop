{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nikitoys/AI_Development_System/spec/agent-work-package.schema.json",
  "title": "Agent Work Package",
  "description": "Minimal machine-checkable contract for Agent Work Packages derived from ai-system/agent-work-package.md.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "parent_task",
    "status",
    "sop",
    "role",
    "action",
    "context",
    "input_artifacts",
    "output_artifacts",
    "scope",
    "out_of_scope",
    "allowed_files",
    "locked_files",
    "forbidden_actions",
    "dependencies",
    "acceptance_criteria",
    "verification_mode",
    "expected_output",
    "review_instructions",
    "risks",
    "questions_or_blockers"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "parent_task": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "Proposed",
        "Draft",
        "Ready",
        "Approved",
        "Blocked",
        "In Progress",
        "Result Submitted",
        "In Review",
        "Rework Required",
        "Accepted",
        "Rejected",
        "Deferred",
        "Archived"
      ]
    },
    "sop": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "action": { "type": "string", "minLength": 1 },
    "context": { "type": "string" },
    "input_artifacts": { "type": "array", "items": { "type": "string" } },
    "output_artifacts": { "type": "array", "items": { "type": "string" } },
    "scope": { "type": "array", "items": { "type": "string" } },
    "out_of_scope": { "type": "array", "items": { "type": "string" } },
    "allowed_files": { "type": "array", "items": { "type": "string" } },
    "locked_files": { "type": "array", "items": { "type": "string" } },
    "forbidden_actions": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
    "verification_mode": {
      "type": "string",
      "enum": [
        "CODE_ONLY_FAST",
        "FAST_VALIDATION",
        "BROWSER_SMOKE",
        "VISUAL_QA"
      ]
    },
    "expected_output": { "type": "array", "items": { "type": "string" } },
    "review_instructions": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "questions_or_blockers": { "type": "array", "items": { "type": "string" } }
  }
}
